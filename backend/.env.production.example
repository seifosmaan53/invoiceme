# ⚠️ PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# 
# IMPORTANT: This is a production example file. You MUST:
# 1. Copy this file to .env: cp .env.production.example .env
# 2. Customize all values for your production environment
# 3. NEVER commit the actual .env file to version control
# 4. Use strong, unique secrets for production
# 5. Validate configuration using: ./scripts/validate-env.sh

# ============================================================================
# Environment & Server Configuration
# ============================================================================

# Node environment: MUST be 'production' for production deployment
NODE_ENV=production

# API server port
API_PORT=3000

# Trust proxy headers (set to true when behind load balancer/reverse proxy)
# Required for correct client IP detection and HTTPS detection
TRUST_PROXY=true

# ============================================================================
# Database Configuration
# ============================================================================

# Production Database (Cloud PostgreSQL)
# Examples: AWS RDS, Heroku Postgres, DigitalOcean Managed Database
DB_HOST=your-production-db-host.rds.amazonaws.com
DB_PORT=5432
DB_USERNAME=your_db_username
DB_PASSWORD=your_secure_db_password
DB_DATABASE=invoiceme_production

# SSL Configuration (required for cloud databases)
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# ============================================================================
# JWT & Authentication Secrets
# ============================================================================

# JWT Secret for access tokens
# REQUIRED: Must be at least 32 characters, cryptographically random
# Generate secure secret: openssl rand -base64 32
# MUST be different from JWT_REFRESH_SECRET
JWT_SECRET=your-production-jwt-secret-minimum-32-characters-cryptographically-random

# JWT access token expiration time
JWT_EXPIRES_IN=15m

# JWT Refresh Secret for refresh tokens
# REQUIRED: Must be at least 32 characters, cryptographically random
# Generate secure secret: openssl rand -base64 32
# MUST be different from JWT_SECRET
JWT_REFRESH_SECRET=your-production-refresh-secret-minimum-32-characters-cryptographically-random

# JWT refresh token expiration time
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================================
# S3/Storage Configuration
# ============================================================================

# S3-Compatible Storage Endpoint
# AWS S3: https://s3.amazonaws.com (or leave empty for default)
# DigitalOcean Spaces: https://nyc3.digitaloceanspaces.com
# Cloudflare R2: https://[account-id].r2.cloudflarestorage.com
S3_ENDPOINT=https://s3.amazonaws.com

# S3 Region
# AWS: us-east-1, us-west-2, eu-west-1, etc.
# DigitalOcean: nyc3, sfo3, etc.
S3_REGION=us-east-1

# S3 Access Key ID
# Create dedicated IAM user with minimal permissions
# Required permissions: s3:PutObject, s3:GetObject, s3:DeleteObject
S3_ACCESS_KEY_ID=your-s3-access-key-id

# S3 Secret Access Key
# Store securely, never commit to git
S3_SECRET_ACCESS_KEY=your-s3-secret-access-key

# S3 Bucket Name
# Use separate bucket with versioning enabled for production
S3_BUCKET=invoiceme-production

# ============================================================================
# Stripe Payment Configuration
# ============================================================================

# Stripe Secret Key (LIVE KEY for production)
# ⚠️ NEVER commit live keys to git
# Get live keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_live_secret_key_here

# Stripe Webhook Secret
# Required for verifying webhook signatures
# Get from: https://dashboard.stripe.com/webhooks
# Webhook endpoint: https://your-domain.com/api/v1/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your_production_webhook_secret_here

# ============================================================================
# Email/SMTP Configuration (Production)
# ============================================================================
# 
# Production email configuration using SendGrid (recommended)
# See DEPLOYMENT.md for detailed setup instructions and alternatives
# 
# SendGrid Setup:
# 1. Sign up at https://sendgrid.com
# 2. Verify your domain (recommended) or single sender
# 3. Create API key with "Mail Send" permissions
# 4. Configure DNS records (SPF, DKIM, DMARC) for domain authentication
# 5. See DEPLOYMENT.md section "Email/SMTP Configuration" for details

# SMTP Host (SendGrid)
SMTP_HOST=smtp.sendgrid.net

# SMTP Port (587 for TLS, recommended)
SMTP_PORT=587

# SMTP Username (SendGrid: always 'apikey')
SMTP_USER=apikey

# SMTP Password (SendGrid API key)
# ⚠️ This is your SendGrid API key, not a password
# Get from: https://app.sendgrid.com/settings/api_keys
SMTP_PASS=your-sendgrid-api-key-here

# Email From Address
# Must be verified domain/email in SendGrid
# Example: noreply@yourdomain.com
EMAIL_FROM=noreply@yourdomain.com

# Frontend URL for email links (password reset, invoice view)
# Production: HTTPS URL of your frontend application
# Used in password reset emails and invoice email links
FRONTEND_URL=https://app.yourdomain.com

# Support Email (displayed in email footers)
# Contact email for customer support inquiries
# Used in invoice email templates
SUPPORT_EMAIL=support@yourdomain.com

# Email Retry Configuration (Optional - Advanced Tuning)
# Maximum number of retry attempts for failed email sends
# Default: 3 (suitable for production)
EMAIL_MAX_RETRIES=3

# Base delay in milliseconds for exponential backoff retry logic
# Actual delays: baseDelay * 2^attempt (e.g., 1000ms, 2000ms, 4000ms)
# Default: 1000 (suitable for production)
EMAIL_RETRY_BASE_DELAY_MS=1000

# ============================================================================
# Alternative Email Services (Optional)
# ============================================================================
# 
# If not using SendGrid, uncomment and configure one of the alternatives below:
# 
# Mailgun:
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=your-mailgun-username
# SMTP_PASS=your-mailgun-smtp-password
# 
# AWS SES:
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your-aws-ses-smtp-username
# SMTP_PASS=your-aws-ses-smtp-password
# 
# Gmail (NOT RECOMMENDED for production - use only for testing):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# ⚠️ Gmail has rate limits and is not suitable for production use

# ============================================================================
# Email Security Notes
# ============================================================================
# ⚠️ NEVER commit real SMTP credentials to git
# ⚠️ Store production credentials in secrets manager (AWS Secrets Manager, etc.)
# ⚠️ Rotate credentials regularly (every 90 days)
# ⚠️ Use verified domain with proper DNS records (SPF, DKIM, DMARC)
# ⚠️ Monitor bounce rates and spam complaints in email service dashboard
# ⚠️ Use environment-specific EMAIL_FROM addresses
# 
# See DEPLOYMENT.md for detailed email configuration and troubleshooting

# ============================================================================
# CORS & Security
# ============================================================================

# CORS Origin - Allowed origins for cross-origin requests
# ⚠️ NEVER use '*' in production - specify exact domains
# 
# Single domain:
CORS_ORIGIN=https://app.yourdomain.com
# 
# Multiple domains (comma-separated):
# CORS_ORIGIN=https://app.yourdomain.com,https://mobile.yourdomain.com
# 
# With subdomains (if supported):
# CORS_ORIGIN=https://*.yourdomain.com

# Rate Limiting Configuration
# Rate limit window in seconds
RATE_LIMIT_TTL=60

# Maximum requests per window
RATE_LIMIT_MAX=100

# Log Level
# Production: info (not debug)
LOG_LEVEL=info

# Enable Swagger API Documentation
# Production: false (disable for security)
ENABLE_SWAGGER=false
